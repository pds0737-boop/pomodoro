    <script>
        const observerOptions = { root: null, rootMargin: '0px', threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                } else {
                    entry.target.classList.remove('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in-up').forEach((el, index) => {
            if(el.closest('.main-screen')) el.style.transitionDelay = `${index * 0.1}s`;
            observer.observe(el);
        });

        // =====================================
        // 1. 웹 알림(Notification) 권한 강제 요청 함수
        // =====================================
        function showNotification(title, body) {
            // Electron 환경이면 IPC로 시스템 알림, 아니면 웹 Notification API 사용
            if (window.electronAPI) {
                window.electronAPI.showNotification(title, body);
            } else if ("Notification" in window && Notification.permission === "granted") {
                new Notification(title, { body: body });
            }
        }

        // =====================================
        // 2. Web Audio API 기반 애플 스타일 사운드
        // =====================================
        let audioCtx = null;

        function getAudioContext() {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            return audioCtx;
        }

        // 애플 스타일 "또롱" 시작음: 맑고 부드러운 단음 2회
        function playStartSound(volume) {
            const ctx = getAudioContext();
            const vol = volume !== undefined ? volume : appData.volume;

            function playTone(startTime, freq, dur) {
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(freq, startTime);
                gain.gain.setValueAtTime(0, startTime);
                gain.gain.linearRampToValueAtTime(vol * 0.45, startTime + 0.01);
                gain.gain.exponentialRampToValueAtTime(0.0001, startTime + dur);
                osc.start(startTime);
                osc.stop(startTime + dur);
            }

            const now = ctx.currentTime;
            playTone(now,        1046.5, 0.25); // C6
            playTone(now + 0.18, 1318.5, 0.30); // E6
        }

        // 애플 스타일 "또롱" 종료음: 3음 하강 차임벨
        function playEndSound(volume) {
            const ctx = getAudioContext();
            const vol = volume !== undefined ? volume : appData.volume;

            function playChime(startTime, freq, dur) {
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(freq, startTime);
                gain.gain.setValueAtTime(0, startTime);
                gain.gain.linearRampToValueAtTime(vol * 0.5, startTime + 0.015);
                gain.gain.exponentialRampToValueAtTime(0.0001, startTime + dur);
                osc.start(startTime);
                osc.stop(startTime + dur);
            }

            const now = ctx.currentTime;
            playChime(now,        1318.5, 0.45); // E6
            playChime(now + 0.22, 1046.5, 0.45); // C6
            playChime(now + 0.44, 783.99, 0.60); // G5
        }

        // 더미 오디오 객체 (볼륨 슬라이더 호환용 — 실제 재생은 Web Audio로 처리)
        const startAudio = { volume: 1.0, currentTime: 0, play: () => Promise.resolve(), pause: () => {} };
        const endAudio   = { volume: 1.0, currentTime: 0, play: () => Promise.resolve(), pause: () => {} };

        // Base64로 인코딩된 초단기 무음 WAV 파일
        const silentAudio = new Audio('data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAgAAAAEA');
        silentAudio.loop = true; // 무한 반복
        
        let isAudioUnlocked = false;

        function unlockAudioOnFirstClick() {
            if (isAudioUnlocked) return;
            // Web Audio Context 초기화 (사용자 제스처 필요)
            getAudioContext().resume().catch(() => {});
            
            // 맥OS 브라우저 정책 우회: 사용자가 클릭하는 시점에 알림 권한을 요청해야 브라우저가 차단하지 않음
            if ("Notification" in window && Notification.permission !== "granted") {
                Notification.requestPermission();
            }

            isAudioUnlocked = true;
            document.body.removeEventListener('click', unlockAudioOnFirstClick);
            document.body.removeEventListener('touchstart', unlockAudioOnFirstClick);
        }

        document.body.addEventListener('click', unlockAudioOnFirstClick);
        document.body.addEventListener('touchstart', unlockAudioOnFirstClick);

        let isSoundOn = true;
        let lastTriggeredTime = ""; 
        let selectedCalendarDate = getLogicalDate(); 

        const subjectColorMap = {
            '재무관리': 'var(--color-sub1)',
            '원가회계': 'var(--color-sub2)',
            '재무회계': 'var(--color-sub3)',
            '세법': 'var(--color-sub4)',
            '경제학': 'var(--color-sub5)',
            '경영학': 'var(--color-sub6)',
            '상법': 'var(--color-sub7)'
        };

        let appData = {
            lastResetDate: '', todaySessions: 0, todayTotalSeconds: 0,
            customFocusMin: 25, customBreakMin: 5,   
            history: {}, subjectStats: {}, reservations: [],
            timeLogs: [], 
            ddayText: "🔥 7월 연습서 개강", ddayDate: "2026-07-01", volume: 1.0 
        };

        if (localStorage.getItem('applePomodoroData')) {
            const parsed = JSON.parse(localStorage.getItem('applePomodoroData'));
            appData = { ...appData, ...parsed };
            if (!appData.subjectStats) appData.subjectStats = {};
            if (!appData.reservations) appData.reservations = [];
            if (!appData.timeLogs) appData.timeLogs = [];
            if (appData.volume === undefined) appData.volume = 1.0;
        }

        // =====================================
        // 과목 실시간 변경 감지 로직
        // =====================================
        let currentSubject = document.getElementById('subjectSelect').value;

        document.getElementById('subjectSelect').addEventListener('change', (e) => {
            const newSubject = e.target.value;
            if (timerState.isPlaying && timerState.isFocusMode && timerState.sessionStartTimeStamp) {
                const now = Date.now();
                if (now - timerState.sessionStartTimeStamp > 60000) {
                    addTimeLogAuto(new Date(timerState.sessionStartTimeStamp), new Date(now), currentSubject);
                    timerState.sessionStartTimeStamp = now;
                    saveRunningState();
                }
            }
            currentSubject = newSubject;
        });

        // =====================================
        // 날짜/시간 유틸리티 함수
        // =====================================
        function getLogicalDate(dateObj = new Date()) {
            const d = new Date(dateObj);
            if (d.getHours() < 5) d.setDate(d.getDate() - 1); 
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function formatHHMM(dateObj) {
            return `${String(dateObj.getHours()).padStart(2,'0')}:${String(dateObj.getMinutes()).padStart(2,'0')}`;
        }

        function getMinutesFromHHMM(hhmm) {
            const [h, m] = hhmm.split(':').map(Number);
            return h * 60 + m;
        }

        function getLogicalMinutes(hhmm) {
            const [h, m] = hhmm.split(':').map(Number);
            const logicalH = h >= 5 ? h - 5 : h + 19;
            return logicalH * 60 + m;
        }

        // =====================================
        // 타임테이블 & 기록 관리 핵심 로직
        // =====================================
        const legendContainer = document.getElementById('subjectLegend');
        for (const [sub, col] of Object.entries(subjectColorMap)) {
            const item = document.createElement('div'); item.className = 'legend-item';
            item.innerHTML = `<div class="legend-color" style="background:${col}"></div><span>${sub}</span>`;
            legendContainer.appendChild(item);
        }

        function recalculateStatsFromLogs() {
            appData.todayTotalSeconds = 0;
            appData.subjectStats = {};
            appData.history = {};

            appData.timeLogs.forEach(log => {
                const startM = getLogicalMinutes(log.startTime);
                let endM = getLogicalMinutes(log.endTime);
                if (endM < startM) endM += 1440; 

                const durationSec = (endM - startM) * 60;
                
                appData.history[log.date] = (appData.history[log.date] || 0) + durationSec;

                if (log.date === getLogicalDate()) {
                    appData.todayTotalSeconds += durationSec;
                    appData.subjectStats[log.subject] = (appData.subjectStats[log.subject] || 0) + durationSec;
                }
            });
        }

        function addTimeLogAuto(startDateObj, endDateObj, subject) {
            if (startDateObj >= endDateObj) return; 
            
            const logDate = getLogicalDate(startDateObj);
            const newLog = {
                id: Date.now(),
                date: logDate,
                startTime: formatHHMM(startDateObj),
                endTime: formatHHMM(endDateObj),
                subject: subject
            };
            
            appData.timeLogs.push(newLog);
            saveDataAndSync();
        }

        function saveDataAndSync() {
            recalculateStatsFromLogs();
            localStorage.setItem('applePomodoroData', JSON.stringify(appData));
            updateDashboard();
            renderCalendar();
            renderTimetable(selectedCalendarDate);
        }

        function renderTimetable(targetDate) {
            selectedCalendarDate = targetDate;
            document.getElementById('ttDateDisplay').textContent = (targetDate === getLogicalDate()) ? "오늘" : targetDate;
            
            const grid = document.getElementById('timetableGrid');
            grid.innerHTML = '';
            
            const dayLogs = appData.timeLogs.filter(l => l.date === targetDate);

            for(let logicalH = 0; logicalH < 24; logicalH++) {
                const actualHour = (logicalH + 5) % 24; 
                
                const row = document.createElement('div');
                row.className = 'tt-row';
                
                const hourLabel = document.createElement('div');
                hourLabel.className = 'tt-hour';
                hourLabel.textContent = `${actualHour}시`;
                
                const track = document.createElement('div');
                track.className = 'tt-track';
                track.onclick = (e) => {
                    if (e.target !== track) return;
                    const rect = track.getBoundingClientRect();
                    const clickX = e.clientX - rect.left;
                    const min = Math.floor((clickX / rect.width) * 60);
                    const clickedTime = `${String(actualHour).padStart(2,'0')}:${String(min).padStart(2,'0')}`;
                    openLogModal(null, clickedTime, targetDate);
                };

                dayLogs.forEach(log => {
                    const sMinTotal = getLogicalMinutes(log.startTime);
                    let eMinTotal = getLogicalMinutes(log.endTime);
                    if (eMinTotal <= sMinTotal) eMinTotal += 1440;

                    const trackStartM = logicalH * 60;
                    const trackEndM = (logicalH + 1) * 60;

                    if (sMinTotal < trackEndM && eMinTotal > trackStartM) {
                        const drawStart = Math.max(sMinTotal, trackStartM) - trackStartM;
                        const drawEnd = Math.min(eMinTotal, trackEndM) - trackStartM;
                        
                        const leftPercent = (drawStart / 60) * 100;
                        const widthPercent = ((drawEnd - drawStart) / 60) * 100;

                        const block = document.createElement('div');
                        block.className = 'tt-log';
                        block.style.left = `${leftPercent}%`;
                        block.style.width = `${widthPercent}%`;
                        block.style.backgroundColor = subjectColorMap[log.subject] || '#999';
                        
                        block.onclick = (e) => { e.stopPropagation(); openLogModal(log); };
                        
                        track.appendChild(block);
                    }
                });

                row.appendChild(hourLabel);
                row.appendChild(track);
                grid.appendChild(row);
            }
        }

        // =====================================
        // 모달 관리 (설정 & 기록 수정)
        // =====================================
        const settingsBtn = document.getElementById('settingsBtn');
        const settingsModal = document.getElementById('settingsModal');
        settingsBtn.addEventListener('click', () => { settingsModal.classList.add('show'); document.body.style.overflow = 'hidden'; });
        document.getElementById('closeSettingsBtn').addEventListener('click', () => { settingsModal.classList.remove('show'); document.body.style.overflow = ''; });
        
        const logEditModal = document.getElementById('logEditModal');
        document.getElementById('closeLogModalBtn').addEventListener('click', () => { logEditModal.classList.remove('show'); });

        window.addEventListener('click', (e) => { 
            if (e.target === settingsModal) { settingsModal.classList.remove('show'); document.body.style.overflow = ''; } 
            if (e.target === logEditModal) { logEditModal.classList.remove('show'); } 
        });

        document.getElementById('focusInput').value = appData.customFocusMin;
        document.getElementById('breakInput').value = appData.customBreakMin;
        document.getElementById('volumeSlider').value = appData.volume;
        document.getElementById('ddayTextInput').value = appData.ddayText;
        document.getElementById('ddayDateInput').value = appData.ddayDate;

        function openLogModal(log = null, defaultStartTime = "09:00", tDate = getLogicalDate()) {
            logEditModal.classList.add('show');
            
            if (log) {
                document.getElementById('logModalTitle').textContent = "기록 수정";
                document.getElementById('logEditId').value = log.id;
                document.getElementById('logEditDate').value = log.date;
                document.getElementById('logSubjectSelect').value = log.subject;
                document.getElementById('logStartTime').value = log.startTime;
                document.getElementById('logEndTime').value = log.endTime;
                document.getElementById('deleteLogBtn').style.display = 'block';
            } else {
                document.getElementById('logModalTitle').textContent = "새 기록 추가";
                document.getElementById('logEditId').value = "";
                document.getElementById('logEditDate').value = tDate;
                document.getElementById('logSubjectSelect').value = document.getElementById('subjectSelect').value;
                document.getElementById('logStartTime').value = defaultStartTime;
                
                const sMin = getMinutesFromHHMM(defaultStartTime);
                const eMin = sMin + 30;
                document.getElementById('logEndTime').value = `${String(Math.floor((eMin%1440)/60)).padStart(2,'0')}:${String(eMin%60).padStart(2,'0')}`;
                
                document.getElementById('deleteLogBtn').style.display = 'none';
            }
        }

        document.getElementById('saveLogBtn').addEventListener('click', () => {
            const id = document.getElementById('logEditId').value;
            const date = document.getElementById('logEditDate').value;
            const subject = document.getElementById('logSubjectSelect').value;
            const start = document.getElementById('logStartTime').value;
            const end = document.getElementById('logEndTime').value;

            if (id) {
                const idx = appData.timeLogs.findIndex(l => l.id == id);
                if (idx > -1) {
                    appData.timeLogs[idx] = { ...appData.timeLogs[idx], subject, startTime: start, endTime: end };
                }
            } else {
                appData.timeLogs.push({ id: Date.now(), date, startTime: start, endTime: end, subject });
            }
            
            saveDataAndSync();
            logEditModal.classList.remove('show');
        });

        document.getElementById('deleteLogBtn').addEventListener('click', () => {
            const id = document.getElementById('logEditId').value;
            if (confirm("정말 이 기록을 삭제하시겠습니까?")) {
                appData.timeLogs = appData.timeLogs.filter(l => l.id != id);
                saveDataAndSync();
                logEditModal.classList.remove('show');
            }
        });

        // =====================================
        // 타이머 및 워커 로직
        // =====================================
        const workerBlob = new Blob([`
            let interval;
            self.onmessage = function(e) {
                if(e.data === 'start') { interval = setInterval(() => self.postMessage('tick'), 200); } 
                else if(e.data === 'stop') { clearInterval(interval); }
            }
        `], {type: 'application/javascript'});
        const timerWorker = new Worker(URL.createObjectURL(workerBlob));

        let timerState = { 
            isFocusMode: true, 
            isPlaying: false, 
            duration: appData.customFocusMin * 60, 
            timeLeft: appData.customFocusMin * 60, 
            targetTime: null,
            sessionStartTimeStamp: null 
        };

        const circle = document.getElementById('progressCircle');
        const radius = circle.r.baseVal.value;
        const circumference = radius * 2 * Math.PI;
        circle.style.strokeDasharray = `${circumference} ${circumference}`;

        async function playBeep(type) {
            if (!isSoundOn) return;
            try {
                if (type === 'start') {
                    playStartSound(appData.volume);
                } else if (type === 'end') {
                    playEndSound(appData.volume);
                }
            } catch (error) {
                console.error("오디오 재생 실패:", error);
            }
        }

        function setProgress(percent) { circle.style.strokeDashoffset = circumference - (percent / 100) * circumference; }

        function checkDailyReset() {
            const logicalToday = getLogicalDate();
            if (appData.lastResetDate !== logicalToday) {
                appData.todaySessions = 0; appData.todayTotalSeconds = 0; 
                appData.lastResetDate = logicalToday; saveDataAndSync(); 
            }
            updateDday();
        }

        function updateDday() {
            const now = new Date(); const targetDateObj = new Date(appData.ddayDate + "T00:00:00");
            now.setHours(0,0,0,0); targetDateObj.setHours(0,0,0,0);
            const diffDays = Math.round((targetDateObj - now) / (1000 * 60 * 60 * 24)); 
            let ddayStr = diffDays > 0 ? `D-${diffDays}` : (diffDays === 0 ? `D-Day` : `D+${Math.abs(diffDays)}`);
            document.getElementById('ddayDisplay').textContent = `${appData.ddayText} ${ddayStr}`;
            let percent = Math.min(100, (appData.todayTotalSeconds / 36000) * 100);
            document.getElementById('dailyProgressFill').style.width = `${percent}%`;
            document.getElementById('dailyProgressText').textContent = `${percent.toFixed(1)}%`;
        }

        function updateTimerUI() {
            const m = Math.floor(timerState.timeLeft / 60); const s = timerState.timeLeft % 60;
            document.getElementById('timerTimeText').textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
            setProgress((timerState.timeLeft / timerState.duration) * 100);
            document.getElementById('timerModeText').textContent = timerState.isFocusMode ? "FOCUS" : "BREAK";
            document.getElementById('timerModeText').style.color = timerState.isFocusMode ? "var(--text-sub)" : "var(--green-accent)";
        }

        function renderSubjectStats() {
            const listEl = document.getElementById('subjectStatsList'); listEl.innerHTML = '';
            for (const [subject, seconds] of Object.entries(appData.subjectStats)) {
                if (seconds > 0) {
                    const li = document.createElement('li'); li.className = 'subject-stat-item';
                    li.innerHTML = `<span style="display:flex; align-items:center; gap:5px;"><div style="width:10px;height:10px;border-radius:2px;background:${subjectColorMap[subject]}"></div>${subject}</span> <strong>${Math.floor(seconds / 60)}m</strong>`;
                    listEl.appendChild(li);
                }
            }
        }

        function updateDashboard() {
            document.getElementById('todaySessions').textContent = appData.todaySessions;
            const h = Math.floor(appData.todayTotalSeconds / 3600); const m = Math.floor((appData.todayTotalSeconds % 3600) / 60);
            document.getElementById('todayTotalTime').textContent = h > 0 ? `${h}h ${m}m` : `${m}m`;
            renderSubjectStats(); updateDday();
        }

        function checkReservation() {
            const now = new Date(); const currentHHMM = formatHHMM(now);
            if (lastTriggeredTime === currentHHMM) return;
            if (!timerState.isPlaying) {
                const match = appData.reservations.find(r => parseInt(r.day) === now.getDay() && r.time === currentHHMM);
                if (match) { lastTriggeredTime = currentHHMM; timerState.isFocusMode = true; timerState.duration = parseInt(match.duration) * 60; timerState.timeLeft = timerState.duration; updateTimerUI(); startTimer(); }
            }
        }
        setInterval(checkReservation, 1000); 

        timerWorker.onmessage = () => { if (!timerState.isPlaying) return; calculateTime(); };

        function calculateTime() {
            const now = Date.now();
            if (now >= timerState.targetTime) {
                timerState.timeLeft = 0;
                updateTimerUI();
                timerWorker.postMessage('stop');
                endSession();
            } else {
                const currentLeft = Math.ceil((timerState.targetTime - now) / 1000);
                if (timerState.timeLeft !== currentLeft) {
                    timerState.timeLeft = currentLeft;
                    updateTimerUI();
                    saveRunningState();
                }
            }
        }

        function startTimer() {
            if (timerState.isPlaying) return;
            checkDailyReset(); 
            
            // OS 앱 낮잠(App Nap) 방지용 무음 루프 오디오 실행
            silentAudio.play().catch(e => console.log("무음 오디오 재생 거부:", e));

            playBeep('start');
            timerState.isPlaying = true;
            timerState.targetTime = Date.now() + (timerState.timeLeft * 1000);
            
            currentSubject = document.getElementById('subjectSelect').value;
            if (timerState.isFocusMode) {
                timerState.sessionStartTimeStamp = Date.now();
            }
            
            document.getElementById('startBtn').style.display = 'none'; 
            document.getElementById('pauseBtn').style.display = 'inline-block'; 
            timerWorker.postMessage('start');
            saveRunningState();
        }

        function pauseTimer() {
            if (!timerState.isPlaying) return;
            timerState.isPlaying = false; 
            timerWorker.postMessage('stop');
            
            // 무음 루프 오디오 정지 (자원 절약)
            silentAudio.pause();
            
            document.getElementById('startBtn').style.display = 'inline-block'; 
            document.getElementById('pauseBtn').style.display = 'none';
            
            const now = Date.now();
            let currentLeft = Math.ceil((timerState.targetTime - now) / 1000);
            if (currentLeft < 0) currentLeft = 0;
            
            if (timerState.isFocusMode && timerState.sessionStartTimeStamp) {
                const sub = document.getElementById('subjectSelect').value;
                if (now - timerState.sessionStartTimeStamp > 60000) {
                    addTimeLogAuto(new Date(timerState.sessionStartTimeStamp), new Date(now), sub);
                }
                timerState.sessionStartTimeStamp = null; 
            }
            
            timerState.timeLeft = currentLeft;
            timerState.targetTime = null;
            updateTimerUI();
            saveRunningState();
        }

        function resetTimer() {
            if (timerState.isPlaying) pauseTimer(); 
            
            timerState.timeLeft = (timerState.isFocusMode ? appData.customFocusMin : appData.customBreakMin) * 60;
            timerState.duration = timerState.timeLeft;
            timerState.targetTime = null;
            timerState.sessionStartTimeStamp = null;
            
            document.getElementById('startBtn').style.display = 'inline-block'; 
            document.getElementById('pauseBtn').style.display = 'none';
            
            updateTimerUI();
            saveRunningState();
        }

        function endSession() {
            timerState.isPlaying = false; 
            
            // 종료 시스템 알림 (시각적 + 시스템 사운드 방어선)
            const title = timerState.isFocusMode ? "공부 세션 종료" : "휴식 세션 종료";
            const bodyMessage = timerState.isFocusMode ? "수고하셨습니다. 이제 휴식 시간입니다!" : "휴식이 끝났습니다. 다시 집중해볼까요?";
            showNotification(title, bodyMessage);
            
            playBeep('end'); 
            
            // 무음 루프 오디오 정지
            silentAudio.pause();

            const wasFocus = timerState.isFocusMode;
            
            if (wasFocus && timerState.sessionStartTimeStamp) {
                appData.todaySessions += 1;
                const sub = document.getElementById('subjectSelect').value;
                addTimeLogAuto(new Date(timerState.sessionStartTimeStamp), new Date(), sub);
                
                timerState.isFocusMode = false; 
                timerState.duration = appData.customBreakMin * 60; 
                document.getElementById('modeToggle').textContent = "🔄 공부 전환";
            } else {
                timerState.isFocusMode = true; 
                timerState.duration = appData.customFocusMin * 60; 
                document.getElementById('modeToggle').textContent = "🔄 휴식 전환";
            }
            
            timerState.sessionStartTimeStamp = null;
            timerState.timeLeft = timerState.duration; 
            timerState.targetTime = null;
            
            updateTimerUI();
            document.getElementById('startBtn').style.display = 'inline-block'; 
            document.getElementById('pauseBtn').style.display = 'none';
            saveRunningState(); 
            
            if (wasFocus) setTimeout(startTimer, 1000); 
        }

        function saveRunningState() {
            localStorage.setItem('pomodoroRunningState', JSON.stringify({ 
                isFocusMode: timerState.isFocusMode, 
                duration: timerState.duration, 
                timeLeft: timerState.timeLeft,
                isPlaying: timerState.isPlaying,
                targetTime: timerState.targetTime,
                sessionStartTimeStamp: timerState.sessionStartTimeStamp,
                activeSubject: currentSubject
            }));
        }

        document.addEventListener("visibilitychange", () => { if (!document.hidden) restoreRunningState(); });

        function restoreRunningState() {
            const savedStr = localStorage.getItem('pomodoroRunningState');
            if (!savedStr) return;
            const saved = JSON.parse(savedStr);
            
            timerState.isFocusMode = saved.isFocusMode;
            timerState.duration = saved.duration;
            timerState.sessionStartTimeStamp = saved.sessionStartTimeStamp;
            
            if (saved.activeSubject) {
                currentSubject = saved.activeSubject;
                document.getElementById('subjectSelect').value = currentSubject;
            }
            
            if (saved.isPlaying && saved.targetTime) {
                const now = Date.now();
                if (now >= saved.targetTime) {
                    timerState.isPlaying = true; timerState.targetTime = saved.targetTime; timerState.timeLeft = saved.timeLeft;
                    calculateTime(); 
                } else {
                    timerState.isPlaying = true; timerState.targetTime = saved.targetTime; timerState.timeLeft = Math.ceil((saved.targetTime - now) / 1000);
                    document.getElementById('startBtn').style.display = 'none'; document.getElementById('pauseBtn').style.display = 'inline-block';
                    timerWorker.postMessage('stop'); timerWorker.postMessage('start');
                    // 복구 시에도 앱 낮잠 방지 오디오 실행
                    silentAudio.play().catch(e => console.log(e));
                }
            } else {
                timerState.isPlaying = false; timerState.timeLeft = saved.timeLeft; timerState.targetTime = null;
                document.getElementById('startBtn').style.display = 'inline-block'; document.getElementById('pauseBtn').style.display = 'none';
            }
            document.getElementById('modeToggle').textContent = timerState.isFocusMode ? "🔄 휴식 전환" : "🔄 공부 전환";
            updateTimerUI();
        }

        document.getElementById('modeToggle').addEventListener('click', () => {
            if(timerState.isPlaying) pauseTimer(); 
            timerState.isFocusMode = !timerState.isFocusMode; 
            timerState.duration = (timerState.isFocusMode ? appData.customFocusMin : appData.customBreakMin) * 60; 
            timerState.timeLeft = timerState.duration; 
            document.getElementById('modeToggle').textContent = timerState.isFocusMode ? "🔄 휴식 전환" : "🔄 공부 전환"; 
            updateTimerUI(); saveRunningState();
        });

        document.getElementById('startBtn').addEventListener('click', startTimer);
        document.getElementById('pauseBtn').addEventListener('click', pauseTimer);
        document.getElementById('resetBtn').addEventListener('click', resetTimer);

        // =====================================
        // 달력 렌더링 로직
        // =====================================
        let currentCalDate = new Date(); 
        function renderCalendar() {
            const grid = document.getElementById('calendarGrid'); grid.innerHTML = '';
            const year = currentCalDate.getFullYear(), month = currentCalDate.getMonth();
            document.getElementById('calendarTitle').textContent = `${year}년 ${month + 1}월`;
            
            ['일','월','화','수','목','금','토'].forEach(l => { 
                const el = document.createElement('div'); el.className = 'day-label'; el.textContent = l; grid.appendChild(el); 
            });
            
            const first = new Date(year, month, 1).getDay(), last = new Date(year, month + 1, 0).getDate();
            for (let i = 0; i < first; i++) grid.appendChild(document.createElement('div'));
            
            for (let d = 1; d <= last; d++) {
                const cell = document.createElement('div'); cell.className = 'cal-cell';
                const dateStr = `${year}-${String(month + 1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
                
                if (dateStr === selectedCalendarDate) cell.classList.add('selected');

                const sec = (appData.history[dateStr] || 0);
                const hrs = sec / 3600;
                cell.style.backgroundColor = sec === 0 ? 'var(--cal-0)' : (hrs >= 10 ? 'var(--cal-10)' : (hrs >= 7 ? 'var(--cal-7)' : (hrs >= 5 ? 'var(--cal-5)' : (hrs >= 3 ? 'var(--cal-3)' : 'var(--cal-1)'))));
                if (hrs >= 7) cell.style.color = '#ffffff';
                
                cell.innerHTML = `<div>${d}</div><div class="cal-time">${Math.floor(sec/3600)}h ${Math.floor((sec%3600)/60)}m</div>`;
                
                cell.onclick = () => { renderTimetable(dateStr); renderCalendar(); };
                
                grid.appendChild(cell);
            }
        }
        
        document.getElementById('prevMonth').addEventListener('click', () => { currentCalDate.setMonth(currentCalDate.getMonth() - 1); renderCalendar(); });
        document.getElementById('nextMonth').addEventListener('click', () => { currentCalDate.setMonth(currentCalDate.getMonth() + 1); renderCalendar(); });

        document.getElementById('applyTimeBtn').addEventListener('click', () => { appData.customFocusMin = parseInt(document.getElementById('focusInput').value); appData.customBreakMin = parseInt(document.getElementById('breakInput').value); saveDataAndSync(); resetTimer(); settingsModal.classList.remove('show'); document.body.style.overflow = ''; });
        document.getElementById('saveDdayBtn').addEventListener('click', () => { appData.ddayText = document.getElementById('ddayTextInput').value; appData.ddayDate = document.getElementById('ddayDateInput').value; saveDataAndSync(); alert("저장되었습니다."); });
        
        document.getElementById('volumeSlider').addEventListener('input', e => { 
            appData.volume = parseFloat(e.target.value); 
            saveDataAndSync(); 
            if (!isSoundOn && appData.volume > 0) { 
                isSoundOn = true; 
                document.getElementById('soundToggle').textContent = "🔊"; 
            } 
        });
        
        document.getElementById('soundToggle').addEventListener('click', () => { isSoundOn = !isSoundOn; document.getElementById('soundToggle').textContent = isSoundOn ? "🔊" : "🔇"; });

        function renderReservations() {
            const listEl = document.getElementById('resList'); listEl.innerHTML = '';
            const dayNames = ["일요일", "월요일", "화요일", "수요일", "목요일", "금요일", "토요일"];
            [...appData.reservations].sort((a,b)=> (a.day||7)-(b.day||7) || a.time.localeCompare(b.time)).forEach(r => {
                const li = document.createElement('li'); li.className = 'res-item';
                li.innerHTML = `<span><strong>[${dayNames[r.day]}]</strong> ${r.time} (${r.duration}분)</span><button class="res-del-btn" onclick="deleteRes(${r.id})">삭제</button>`;
                listEl.appendChild(li);
            });
        }
        const toggleResListBtn = document.getElementById('toggleResListBtn'); const resList = document.getElementById('resList'); let isResListVisible = true;
        toggleResListBtn.addEventListener('click', () => { isResListVisible = !isResListVisible; resList.style.display = isResListVisible ? 'flex' : 'none'; toggleResListBtn.textContent = isResListVisible ? '목록 숨기기 ▴' : '목록 보기 ▾'; });
        document.getElementById('addResBtn').addEventListener('click', () => {
            const checked = document.querySelectorAll('#dayCheckboxGroup input:checked'); const time = document.getElementById('resTime').value; const dur = document.getElementById('resDuration').value;
            if (!checked.length || !time) return alert('요일과 시간을 선택해주세요!');
            checked.forEach((cb, i) => appData.reservations.push({id: Date.now()+i, day: parseInt(cb.value), time, duration: dur}));
            saveDataAndSync(); renderReservations(); checked.forEach(cb => cb.checked = false);
            if(!isResListVisible) { isResListVisible = true; resList.style.display = 'flex'; toggleResListBtn.textContent = '목록 숨기기 ▴'; }
        });
        window.deleteRes = id => { appData.reservations = appData.reservations.filter(r => r.id !== id); saveDataAndSync(); renderReservations(); };

        checkDailyReset(); 
        recalculateStatsFromLogs();
        updateTimerUI(); 
        updateDashboard(); 
        renderReservations(); 
        renderCalendar(); 
        renderTimetable(getLogicalDate());
        restoreRunningState(); 
    </script>
</body>
</html>
